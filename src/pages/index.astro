---
import Base from '../layouts/Base.astro';
---
<Base>

  <!-- NAV -->
  <nav>
    <div class="nav-inner">
      <a href="#" class="nav-brand">
        <img src="/assets/EVO-logo.svg" alt="EVO" class="nav-mark">
        <span class="nav-name">Communication Lab</span>
      </a>
      <ul class="nav-links">
        <li><a href="#servicios" data-es="Servicios" data-en="Services">Servicios</a></li>
        <li><a href="#proceso" data-es="Proceso" data-en="Process">Proceso</a></li>
        <li><a href="#contacto" data-es="Contacto" data-en="Contact">Contacto</a></li>
      </ul>
      <div class="nav-controls">
        <button class="nav-toggle" onclick="toggleLang()" id="lang-btn" aria-label="Switch language">EN</button>
        <button class="nav-toggle" onclick="toggleTheme()" id="theme-btn" aria-label="Toggle dark mode">
          <i class="ph ph-sun" id="theme-icon"></i>
        </button>
        <a href="#contacto" class="nav-cta">
          <span data-es="Escribir" data-en="Contact">Escribir</span>
          <i class="ph ph-paper-plane-tilt" aria-hidden="true"></i>
        </a>
      </div>
    </div>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-center wrap">
      <p class="label hero-eyebrow" data-es="Estrategia · Marca · Sistemas digitales" data-en="Strategy · Brand · Digital systems">Estrategia · Marca · Sistemas digitales</p>
      <h1 class="hero-h1">
        <span data-es="CLARIDAD" data-en="CLARITY">CLARIDAD</span><br>
        <span data-es="SOBRE EL" data-en="OVER THE">SOBRE EL</span><br>
        <span data-es="RUIDO" data-en="NOISE">RUIDO</span><span class="hero-accent">.</span>
      </h1>
      <p class="hero-copy" data-es="EVO construye la marca, el sitio web y los materiales que tu empresa necesita para ganar la confianza de sus clientes antes de la primera reunión." data-en="EVO builds the brand, the website, and the materials your business needs to earn your clients' trust before the first meeting.">EVO construye la marca, el sitio web y los materiales que tu empresa necesita para ganar la confianza de sus clientes antes de la primera reunión.</p>
      <div class="hero-actions">
        <a href="mailto:info@evo.cl" class="btn btn-primary">
          <i class="ph ph-envelope-simple" aria-hidden="true"></i>
          <span data-es="Escribir por email" data-en="Get in touch">Escribir por email</span>
        </a>
        <a href="https://wa.me/56982393697?text=Hola%20Felipe%2C%20te%20escribo%20desde%20evo.cl" class="btn btn-outline" target="_blank" rel="noopener">
          <i class="ph ph-whatsapp-logo" aria-hidden="true"></i>
          <span>WhatsApp</span>
        </a>
      </div>
    </div>
  </section>

  <!-- QUÉ ES EVO -->
  <section class="about section-py">
    <div class="wrap">
      <div class="about-inner">
        <div>
          <p class="label" data-es="Qué es EVO Communication Lab" data-en="What is EVO Communication Lab">Qué es EVO Communication Lab</p>
          <h2 class="about-heading">
            <span data-es="Estrategia<br>digital que<br>" data-en="Digital strategy<br>that<br>">Estrategia<br>digital que<br></span><span class="accent" data-es="se queda." data-en="lasts.">se queda.</span>
          </h2>
        </div>
        <div>
          <p class="p-lead" data-es="EVO Communication Lab trabaja con empresas que tienen un producto o servicio sólido, y necesitan comunicarlo a la altura de lo que ofrecen." data-en="EVO Communication Lab works with businesses that have a strong product or service, and need to communicate it at the level of what they actually offer.">EVO Communication Lab trabaja con empresas que tienen un producto o servicio sólido, y necesitan comunicarlo a la altura de lo que ofrecen.</p>
          <p class="p-body" data-es="EVO diseña identidades de marca, construye presencia digital y produce los materiales con los que un negocio se presenta ante clientes, socios y compradores. Todo lo que entrega es <strong>concreto, documentado, y puede operar sin depender de EVO</strong>." data-en="EVO designs brand identities, builds digital presence, and produces the materials a business uses to present itself to clients, partners, and buyers. Everything it delivers is <strong>concrete, documented, and able to run without depending on EVO</strong>.">EVO diseña identidades de marca, construye presencia digital y produce los materiales con los que un negocio se presenta ante clientes, socios y compradores. Todo lo que entrega es <strong>concreto, documentado, y puede operar sin depender de EVO</strong>.</p>
          <p class="p-body" data-es="Hoy EVO trabaja con proveedores de la gran minería chilena en sistemas de marca, fichas técnicas y materiales de venta. El alcance lo define el negocio: EVO entra con preguntas y sale con un <strong>entregable documentado y transferible</strong>." data-en="Today EVO works with suppliers to Chile's mining industry on brand systems, technical sheets, and sales materials. Scope is defined by the business: EVO comes in with questions and leaves with a <strong>documented, transferable deliverable</strong>.">Hoy EVO trabaja con proveedores de la gran minería chilena en sistemas de marca, fichas técnicas y materiales de venta. El alcance lo define el negocio: EVO entra con preguntas y sale con un <strong>entregable documentado y transferible</strong>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section class="services section-py" id="servicios">
    <div class="wrap">
      <div class="section-header">
        <p class="label" data-es="Servicios" data-en="Services">Servicios</p>
        <h2 class="section-title" data-es="De la estrategia<br>al entregable." data-en="From strategy<br>to delivery.">De la estrategia<br>al entregable.</h2>
      </div>
      <div class="services-list">
        <div class="service-row">
          <div class="service-title-col">
            <div class="service-num"><i class="ph ph-palette" aria-hidden="true"></i> 01</div>
            <div class="service-title" data-es="Identidad de marca" data-en="Brand identity">Identidad de marca</div>
          </div>
          <p class="p-body" data-es="Logo, kit de marca, paleta, tipografía y guía de uso, pensados para que <strong>cualquier persona del equipo pueda aplicarlos sin llamar a un diseñador</strong>." data-en="Logo, brand kit, palette, typography, and usage guide, made so <strong>anyone on the team can apply them without calling a designer</strong>.">Logo, kit de marca, paleta, tipografía y guía de uso, pensados para que <strong>cualquier persona del equipo pueda aplicarlos sin llamar a un diseñador</strong>.</p>
        </div>
        <div class="service-row">
          <div class="service-title-col">
            <div class="service-num"><i class="ph ph-globe-simple" aria-hidden="true"></i> 02</div>
            <div class="service-title" data-es="Presencia digital" data-en="Digital presence">Presencia digital</div>
          </div>
          <p class="p-body" data-es="Sitios web, landing pages y tiendas online <strong>construidos para convertir</strong>: que quien llega entienda qué haces, confíe y tome acción." data-en="Websites, landing pages, and online stores <strong>built to convert</strong>: visitors understand what you do, trust you, and take action.">Sitios web, landing pages y tiendas online <strong>construidos para convertir</strong>: que quien llega entienda qué haces, confíe y tome acción.</p>
        </div>
        <div class="service-row">
          <div class="service-title-col">
            <div class="service-num"><i class="ph ph-presentation-chart" aria-hidden="true"></i> 03</div>
            <div class="service-title" data-es="Comunicación técnica y comercial" data-en="Technical & sales communication">Comunicación técnica y comercial</div>
          </div>
          <p class="p-body" data-es="Fichas de producto, presentaciones, propuestas y catálogos: <strong>documentos que funcionan sin explicación adicional</strong> ante clientes, licitaciones o distribuidores." data-en="Product sheets, presentations, proposals, and catalogs: <strong>documents that work without additional explanation</strong> for clients, tenders, or distributors.">Fichas de producto, presentaciones, propuestas y catálogos: <strong>documentos que funcionan sin explicación adicional</strong> ante clientes, licitaciones o distribuidores.</p>
        </div>
        <div class="service-row">
          <div class="service-title-col">
            <div class="service-num"><i class="ph ph-cpu" aria-hidden="true"></i> 04</div>
            <div class="service-title" data-es="Consultoría y sistemas digitales" data-en="Digital consulting & systems">Consultoría y sistemas digitales</div>
          </div>
          <p class="p-body" data-es="Diagnóstico, herramientas digitales y automatización de flujos. <strong>EVO entra con preguntas y sale con un sistema que el equipo puede operar solo</strong>." data-en="Diagnosis, digital tools, and workflow automation. <strong>EVO comes in with questions and leaves with a system the team can run on its own</strong>.">Diagnóstico, herramientas digitales y automatización de flujos. <strong>EVO entra con preguntas y sale con un sistema que el equipo puede operar solo</strong>.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CÓMO TRABAJAMOS -->
  <section class="process section-py" id="proceso">
    <div class="wrap">
      <div class="section-header">
        <p class="label" data-es="Cómo trabajamos" data-en="How we work">Cómo trabajamos</p>
        <h2 class="section-title" data-es="Principios<br>de trabajo." data-en="Working<br>principles.">Principios<br>de trabajo.</h2>
      </div>
      <div class="process-list">
        <div class="process-item">
          <div class="process-title-col">
            <div class="process-num">01</div>
            <div class="process-title" data-es="Diagnóstico primero." data-en="Diagnosis first.">Diagnóstico primero.</div>
          </div>
          <p class="p-body" data-es="Antes de proponer cualquier solución, EVO busca entender el problema real. Entra con preguntas, no con catálogos. El alcance lo define el negocio, no el proveedor." data-en="Before proposing any solution, EVO seeks to understand the real problem. It comes in with questions, not catalogs. Scope is defined by the business, not the vendor.">Antes de proponer cualquier solución, EVO busca entender el problema real. Entra con preguntas, no con catálogos. El alcance lo define el negocio, no el proveedor.</p>
        </div>
        <div class="process-item">
          <div class="process-title-col">
            <div class="process-num">02</div>
            <div class="process-title" data-es="Trabajo real desde el primer día." data-en="Real work from day one.">Trabajo real desde el primer día.</div>
          </div>
          <p class="p-body" data-es="Sin grandes presentaciones ni fases de definición interminables. Los primeros entregables aparecen en la primera semana de colaboración. El cliente ve progreso desde el inicio." data-en="No big presentations, no endless definition phases. First deliverables appear in the first week. The client sees progress from day one.">Sin grandes presentaciones ni fases de definición interminables. Los primeros entregables aparecen en la primera semana de colaboración. El cliente ve progreso desde el inicio.</p>
        </div>
        <div class="process-item">
          <div class="process-title-col">
            <div class="process-num">03</div>
            <div class="process-title" data-es="Sistemas, no dependencias." data-en="Systems, not dependencies.">Sistemas, no dependencias.</div>
          </div>
          <p class="p-body" data-es="El trabajo bien hecho termina cuando el cliente puede operar solo. EVO documenta, transfiere criterio y se asegura de que el equipo pueda seguir sin su intervención. No crea dependencias a propósito." data-en="Well-done work ends when the client can operate on their own. EVO documents, transfers judgment, and makes sure the team can continue without its involvement. It doesn't create dependencies on purpose.">El trabajo bien hecho termina cuando el cliente puede operar solo. EVO documenta, transfiere criterio y se asegura de que el equipo pueda seguir sin su intervención. No crea dependencias a propósito.</p>
        </div>
        <div class="process-item">
          <div class="process-title-col">
            <div class="process-num">04</div>
            <div class="process-title" data-es="Remoto por diseño." data-en="Remote by design.">Remoto por diseño.</div>
          </div>
          <p class="p-body" data-es="EVO trabaja con negocios en todo el mundo. El proceso está diseñado para funcionar a cualquier distancia: documentación clara, comunicación asíncrona y entregables que no necesitan explicación adicional." data-en="EVO works with businesses worldwide. The process is designed to work at any distance: clear documentation, async communication, and deliverables that need no additional explanation.">EVO trabaja con negocios en todo el mundo. El proceso está diseñado para funcionar a cualquier distancia: documentación clara, comunicación asíncrona y entregables que no necesitan explicación adicional.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FORMATOS -->
  <section class="formats section-py">
    <div class="wrap">
      <div class="section-header">
        <p class="label" data-es="Por dónde empezar" data-en="Where to start">Por dónde empezar</p>
        <h2 class="section-title" data-es="Tres formas<br>de trabajar." data-en="Three ways<br>to engage.">Tres formas<br>de trabajar.</h2>
      </div>
      <div class="formats-grid">
        <div class="format-card">
          <div class="format-top">
            <i class="ph ph-stethoscope format-icon" aria-hidden="true"></i>
            <div class="format-name" data-es="Diagnóstico EVO" data-en="EVO Diagnostic">Diagnóstico EVO</div>
          </div>
          <p class="p-body" data-es="Sesión de 90 minutos más informe con el <strong>estado actual de comunicación</strong> y recomendaciones priorizadas. Precio fijo, sin compromiso de continuidad." data-en="90-minute session plus a report on the <strong>current state of communications</strong> and prioritized recommendations. Fixed price, no commitment to continue.">Sesión de 90 minutos más informe con el <strong>estado actual de comunicación</strong> y recomendaciones priorizadas. Precio fijo, sin compromiso de continuidad.</p>
        </div>
        <div class="format-card">
          <div class="format-top">
            <i class="ph ph-target format-icon" aria-hidden="true"></i>
            <div class="format-name" data-es="Proyecto puntual" data-en="Fixed-scope project">Proyecto puntual</div>
          </div>
          <p class="p-body" data-es="<strong>Entregable definido, precio fijo, plazo cerrado.</strong> Sin horas abiertas ni alcance que se expande. Para quienes tienen una necesidad concreta." data-en="<strong>Defined deliverable, fixed price, closed deadline.</strong> No open hours, no expanding scope. For those with a specific need."><strong>Entregable definido, precio fijo, plazo cerrado.</strong> Sin horas abiertas ni alcance que se expande. Para quienes tienen una necesidad concreta.</p>
        </div>
        <div class="format-card">
          <div class="format-top">
            <i class="ph ph-calendar-check format-icon" aria-hidden="true"></i>
            <div class="format-name" data-es="Retainer mensual" data-en="Monthly retainer">Retainer mensual</div>
          </div>
          <p class="p-body" data-es="Horas dedicadas, <strong>prioridad de agenda y continuidad de criterio</strong>. Para negocios que necesitan soporte recurrente sin contratar un equipo interno." data-en="Dedicated hours, <strong>calendar priority, and continuity of judgment</strong>. For businesses that need recurring support without hiring an internal team.">Horas dedicadas, <strong>prioridad de agenda y continuidad de criterio</strong>. Para negocios que necesitan soporte recurrente sin contratar un equipo interno.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CONTACTO -->
  <section class="contact-section section-py" id="contacto">
    <div class="wrap contact-grid">
      <div>
        <p class="label contact-cta-label" data-es="Contacto" data-en="Contact">Contacto</p>
        <h2 class="contact-h2" data-es="Trabajemos<br>juntos." data-en="Let's work<br>together.">Trabajemos<br>juntos.</h2>
        <p class="contact-sub" data-es="No necesitas tener un proyecto definido para contactar a EVO. Desde una duda puntual hasta un sistema completo, así se empieza. EVO responde en menos de 24 horas." data-en="You don't need a defined project to reach out to EVO. From a quick question to a full system, this is where it starts. EVO responds within 24 hours.">No necesitas tener un proyecto definido para contactar a EVO. Desde una duda puntual hasta un sistema completo, así se empieza. EVO responde en menos de 24 horas.</p>
        <div class="contact-direct">
          <a href="mailto:info@evo.cl" class="btn btn-outline-white">
            <i class="ph ph-envelope-simple" aria-hidden="true"></i> info@evo.cl
          </a>
          <a href="https://wa.me/56982393697?text=Hola%20Felipe%2C%20te%20escribo%20desde%20evo.cl" class="btn btn-outline-white" target="_blank" rel="noopener">
            <i class="ph ph-whatsapp-logo" aria-hidden="true"></i> WhatsApp
          </a>
        </div>
      </div>
      <form class="contact-form" action="/.netlify/functions/contact" method="POST">
        <div class="form-row">
          <div class="form-field">
            <label class="form-label" for="nombre" data-es="Nombre" data-en="Name">Nombre</label>
            <input class="form-input" type="text" id="nombre" name="nombre" placeholder="Tu nombre" required>
          </div>
          <div class="form-field">
            <label class="form-label" for="empresa" data-es="Empresa" data-en="Company">Empresa</label>
            <input class="form-input" type="text" id="empresa" name="empresa" placeholder="Tu empresa">
          </div>
        </div>
        <div class="form-field">
          <label class="form-label" for="email">Email</label>
          <input class="form-input" type="email" id="email" name="email" placeholder="tu@email.com" required>
        </div>
        <div class="form-field">
          <label class="form-label" for="mensaje" data-es="Mensaje" data-en="Message">Mensaje</label>
          <textarea class="form-input" id="mensaje" name="mensaje" placeholder="Cuéntanos qué necesitas..." required></textarea>
        </div>
        <!-- Honeypot anti-spam: invisible to humans, bots fill it blindly -->
        <div style="position:absolute;left:-9999px;top:-9999px;" aria-hidden="true">
          <label for="website">Website</label>
          <input type="text" id="website" name="website" tabindex="-1" autocomplete="off">
        </div>
        <input type="hidden" name="ts" id="form-ts">
        <button type="submit" class="btn btn-primary btn-block">
          <span data-es="Enviar mensaje" data-en="Send message">Enviar mensaje</span>
          <i class="ph ph-arrow-right" aria-hidden="true"></i>
        </button>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer>
    <div class="footer-inner">
      <div class="footer-brand">
        <img src="/assets/EVO-logo.svg" alt="EVO" class="footer-mark">
        <span class="footer-name">EVO Communication Lab</span>
      </div>
      <span class="footer-info">© 2026 EVO Communication Lab · evo.cl · <a href="https://faguilera.com" target="_blank" rel="noopener" data-es="Estudio de Felipe Aguilera" data-en="Felipe Aguilera's studio">Estudio de Felipe Aguilera</a></span>
    </div>
  </footer>

  <script is:inline src="/scripts/home.js"></script>

</Base>
